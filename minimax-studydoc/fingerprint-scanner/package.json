{
  "name": "repo-fingerprint-scanner",
  "version": "1.0.0",
  "description": "Enterprise Git Repository Fingerprint Scanner - File Indexer and Fingerprint Engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
